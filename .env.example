# ── USE Stock Dashboard — Environment Variables Reference ─────────────────────
# This file is safe to commit. It documents all required/optional env vars.
# For local development: copy to .env.local and fill in real values.
# For Vercel: add each variable under Project → Settings → Environment Variables.

# Required for the /api/update-prices cron endpoint.
# Generate with: openssl rand -hex 32
CRON_SECRET=your_cron_secret_here

# Optional — fallback price API if African Financials scraping fails.
# Expected JSON: [{ ticker, currentPrice, changePercent, change }]
AFRICAN_MARKET_FALLBACK_URL=

# Optional — Bearer token for the fallback API (leave blank if not needed).
AFRICAN_MARKET_FALLBACK_TOKEN=
